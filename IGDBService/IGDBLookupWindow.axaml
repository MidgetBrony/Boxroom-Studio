<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Boxroom_Studio.IGDBLookupWindow"
        Width="900"
        Height="600"
        Title="Search IGDB"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10"
          RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="300,*">

        <!-- Search -->
        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">

            <TextBox x:Name="SearchBox"
                     PlaceholderText="Search for a game..." 
                     KeyDown="SearchButton_KeyDown"/>

            <Button Grid.Column="1"
                    x:Name="SearchButton"
                    Content="Search"
                    Click="SearchIgdbButton_Click"/>

        </Grid>

        <!-- Results -->
        <GroupBox Grid.Row="1"
                  Grid.Column="0"
                  Header="Results"
                  Margin="0,10,10,10">

            <ListBox x:Name="ResultsList" SelectionChanged="ResultsList_SelectionChanged"/>

        </GroupBox>

        <!-- Preview -->
        <GroupBox Grid.Row="1"
                  Grid.Column="1"
                  Header="Preview"
                  Margin="0,10,0,10">

            <Grid Margin="10"
                  ColumnDefinitions="220,*"
                  RowDefinitions="Auto,*">

                <!-- Cover -->

                <StackPanel>

                    <Border Width="200"
                            Height="300"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Image x:Name="CoverImage"
                               Stretch="UniformToFill"/>

                    </Border>

                </StackPanel>

                <!-- Details -->

                <StackPanel Grid.Column="1"
                            Margin="15,0,0,0"
                            Spacing="6">

                    <TextBlock x:Name="GameName"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <TextBlock x:Name="ReleaseDate"/>

                    <TextBlock x:Name="Developer"/>

                    <TextBlock x:Name="Publisher"/>

                    <TextBlock x:Name="Genres"/>

                    <TextBlock Text="Summary"
                               Margin="0,10,0,0"
                               FontWeight="Bold"/>

                    <TextBox x:Name="SummaryBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="250"/>

                </StackPanel>

            </Grid>

        </GroupBox>

        <!-- Buttons -->

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">

            <Button x:Name="UseSelectedButton"
                    Content="Use Selected" Click="UseSelectedButton_Click"/>

            <Button x:Name="CancelButton"
                    Content="Cancel"/>

        </StackPanel>

    </Grid>

</Window>