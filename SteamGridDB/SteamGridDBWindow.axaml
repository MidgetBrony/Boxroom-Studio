<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Boxroom_Studio.SteamGridDBWindow"
        Width="900"
        Height="650"
        Title="SteamGridDB Artwork">

    <Grid Margin="10"
          RowDefinitions="Auto,*,Auto">

        <TextBlock x:Name="TitleText"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="SteamGridDB Covers"/>

        <ScrollViewer Grid.Row="1"
                      Margin="0,10">

            <WrapPanel x:Name="CoverPanel"
                       Orientation="Horizontal"/>

        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">

            <Button x:Name="UseSelectedButton"
                    Content="Use Selected" Click="UseSelectedButton_Click"/>

            <Button x:Name="CancelButton"
                    Content="Cancel" Click="CancelButton_Click"/>

        </StackPanel>

    </Grid>

</Window>