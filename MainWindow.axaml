<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Boxroom_Studio"
        x:Class="Boxroom_Studio.MainWindow"
        Width="1000"
        Height="800"
        Title="Boxroom Studio">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Padding="10">
            <StackPanel Orientation="Horizontal" Spacing="8">

                <Button Content="New" Click="NewGame_Click"/>
                
                <Button x:Name="SyncOwnedGamesButton" Content="Sync Owned__Games.json" Click="SyncGamesOwned">
                <ToolTip.Tip>
            <StackPanel MaxWidth="350" Spacing="4">
                        <TextBlock TextWrapping="Wrap">
                            Scans the Boxroom cache for custom games and adds any missing
                            entries to <Run FontWeight="Bold">owned_games.json</Run>.
                        </TextBlock>

                        <TextBlock Foreground="HotPink"
                                   FontWeight="Bold">
                            ⚠ Important
                        </TextBlock>

                        <TextBlock Foreground="HotPink"
                                   TextWrapping="Wrap">
When Boxroom refreshes your Steam library, it may recreate owned_games.json, removing custom game entries. Run this command again to restore them.
                        </TextBlock>
                    </StackPanel>
                </ToolTip.Tip>
                </Button>
                <Button Content="Settings" Click="OpenSettings_Click"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- Game List -->
        <Border Grid.Column="0"
                Margin="10">

            <DockPanel LastChildFill="True">

                <!-- Search -->
                <TextBox x:Name="GameSearchBox"
                         DockPanel.Dock="Top"
                         Margin="0,0,0,8"
                         Watermark="Search games..."
                         TextChanged="GameSearchBox_TextChanged"/>

                <!-- Game List -->
                <ListBox x:Name="GamesList"
                         SelectionChanged="GamesList_SelectionChanged"/>

            </DockPanel>

        </Border>

            <!-- Editor -->
            <Border Grid.Column="1"
                    Margin="10">

                <local:GameEditor x:Name="GameEditor"/>

            </Border>

        </Grid>

        <!-- Status -->
        <Border Grid.Row="2"
                Padding="8">

            <TextBlock x:Name="StatusText" Text="Ready"/>

        </Border>

    </Grid>

</Window>